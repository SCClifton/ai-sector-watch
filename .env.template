# AI Sector Watch - environment template.
# Copy to .env.local and replace placeholders with values or secret-manager
# references. Never commit .env.local. Run secret-bearing commands via:
#
#   op run --env-file=.env.local -- <command>
#
# Required secrets.
ANTHROPIC_API_KEY=<anthropic-api-key>
SUPABASE_DB_URL=<supabase-db-url>
ADMIN_PASSWORD=<admin-password>
FIRECRAWL_API_KEY=<firecrawl-api-key>

# Non-secret config:
PIPELINE_LOG_LEVEL=INFO
DIGEST_OUTPUT_DIR=./data/digests
ANTHROPIC_BUDGET_USD_PER_RUN=2
ANTHROPIC_MODEL=claude-sonnet-4-6
FIRECRAWL_BUDGET_CREDITS_PER_RUN=200
