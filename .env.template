# AI Sector Watch - environment template.
# Copy to .env.local and replace the op:// references with the exact paths to
# your 1Password items. Never commit .env.local. Run secret-bearing commands via:
#
#   op run --env-file=.env.local -- <command>
#
# Required secrets (provided by 1Password).
# `op run --env-file` does not parse spaces in item names reliably.
# Use item UUIDs in local env files when the 1Password item name has spaces.
ANTHROPIC_API_KEY=op://Private/<anthropic-item-uuid>/credential
SUPABASE_DB_URL=op://Private/<supabase-item-uuid>/connection_string
ADMIN_PASSWORD=op://Private/<admin-item-uuid>/password

# Non-secret config:
PIPELINE_LOG_LEVEL=INFO
DIGEST_OUTPUT_DIR=./data/digests
ANTHROPIC_BUDGET_USD_PER_RUN=2
ANTHROPIC_MODEL=claude-sonnet-4-6
